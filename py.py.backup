#!/usr/bin/env python3

from pathlib import Path

# Diretório base do projeto
BASE_DIR = Path(__file__).parent.resolve()

# Texto antigo e novo
OLD = "NevermoreSSH/hop/"
NEW = "faizalsalato/ssh/"

# Extensões binárias para ignorar
BINARY_EXTENSIONS = {
    ".png", ".jpg", ".jpeg", ".gif", ".webp", ".ico",
    ".zip", ".tar", ".gz", ".xz", ".7z", ".rar",
    ".deb", ".rpm",
    ".so", ".dll", ".exe", ".bin",
    ".mp3", ".mp4", ".mkv", ".avi",
    ".pdf"
}

modified = 0
checked = 0

print("=" * 60)
print("SUBSTITUINDO REPOSITÓRIOS")
print("=" * 60)
print(f"Antigo: {OLD}")
print(f"Novo   : {NEW}")
print()

for file in BASE_DIR.rglob("*"):
    if not file.is_file():
        continue

    # Ignorar backups
    if file.name.endswith(".backup"):
        continue

    # Ignorar arquivos binários conhecidos
    if file.suffix.lower() in BINARY_EXTENSIONS:
        continue

    checked += 1

    try:
        content = file.read_text(encoding="utf-8", errors="ignore")

        if OLD not in content:
            continue

        # Backup
        backup_file = Path(str(file) + ".backup")
        backup_file.write_text(content, encoding="utf-8")

        # Substituição
        content = content.replace(OLD, NEW)

        # Salvar
        file.write_text(content, encoding="utf-8")

        modified += 1
        print(f"✓ {file.relative_to(BASE_DIR)}")

    except Exception as e:
        print(f"✗ {file}: {e}")

print()
print("=" * 60)
print("RESUMO")
print("=" * 60)
print(f"Arquivos verificados : {checked}")
print(f"Arquivos modificados : {modified}")
print(f"Backups criados      : {modified}")
print("=" * 60)